{%- liquid
  assign section_id = section.id
-%}

<section id="fp-snap-{{ section_id }}" class="fp-snap">
  {%- if section.blocks.size > 1 -%}
    <div class="fp-snap__indicator" aria-hidden="true">
      {%- for block in section.blocks -%}
        <span class="{% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}"></span>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="fp-snap__wrapper">
    {%- for block in section.blocks -%}
      <article class="fp-snap__panel" {{ block.shopify_attributes }}>
        {%- if block.settings.link != blank -%}
          <a
            class="fp-snap__panel-link"
            href="{{ block.settings.link }}"
            {% if block.settings.open_in_new_tab %}
              target="_blank" rel="noopener noreferrer"
            {% endif %}
          >
        {%- else -%}
          <div class="fp-snap__panel-link">
        {%- endif -%}

          <div class="fp-snap__media fp-snap__media--desktop">
            {%- if block.settings.desktop_video_url != blank -%}
              <video
                class="fp-snap__video"
                autoplay
                loop
                muted
                playsinline
                preload="auto"
              >
                <source src="{{ block.settings.desktop_video_url | escape }}" type="video/mp4">
              </video>
            {%- elsif block.settings.desktop_image != blank -%}
              {{ block.settings.desktop_image | image_url: width: 2400 | image_tag: loading: 'lazy', decoding: 'async', class: 'fp-snap__image', widths: '750,1080,1600,2000,2400', sizes: '100vw' }}
            {%- else -%}
              {{ 'hero-apparel-1' | placeholder_svg_tag: 'fp-snap__placeholder' }}
            {%- endif -%}
          </div>

          <div class="fp-snap__media fp-snap__media--mobile">
            {%- if block.settings.mobile_video_url != blank -%}
              <video
                class="fp-snap__video"
                autoplay
                loop
                muted
                playsinline
                preload="auto"
              >
                <source src="{{ block.settings.mobile_video_url | escape }}" type="video/mp4">
              </video>
            {%- elsif block.settings.mobile_image != blank -%}
              {{ block.settings.mobile_image | image_url: width: 1200 | image_tag: loading: 'lazy', decoding: 'async', class: 'fp-snap__image', widths: '375,640,828,1080,1200', sizes: '100vw' }}
            {%- else -%}
              {{ 'hero-apparel-2' | placeholder_svg_tag: 'fp-snap__placeholder' }}
            {%- endif -%}
          </div>

        {%- if block.settings.link != blank -%}
          </a>
        {%- else -%}
          </div>
        {%- endif -%}
      </article>
    {%- endfor -%}
  </div>
</section>

<style>
  #fp-snap-{{ section_id }} {
    position: relative;
    min-height: 100vh;
    color: #fff;
  }

  #fp-snap-{{ section_id }} .fp-snap__wrapper {
    height: 100vh;
    overflow-y: scroll;
    scroll-snap-type: y mandatory;
    scroll-behavior: smooth;
  }

  #fp-snap-{{ section_id }} .fp-snap__panel {
    position: relative;
    height: 100vh;
    overflow: hidden;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  #fp-snap-{{ section_id }} .fp-snap__panel-link {
    position: relative;
    display: block;
    width: 100%;
    height: 100%;
  }

  #fp-snap-{{ section_id }} .fp-snap__media {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #fp-snap-{{ section_id }} .fp-snap__media--desktop {
    display: block;
  }

  #fp-snap-{{ section_id }} .fp-snap__media--mobile {
    display: none;
  }

  #fp-snap-{{ section_id }} .fp-snap__image,
  #fp-snap-{{ section_id }} .fp-snap__video,
  #fp-snap-{{ section_id }} .fp-snap__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #fp-snap-{{ section_id }} .fp-snap__indicator {
    position: absolute;
    top: 50%;
    right: 2rem;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    z-index: 2;
    pointer-events: none;
  }

  #fp-snap-{{ section_id }} .fp-snap__indicator span {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 50%;
    border: 1px solid rgba(255, 255, 255, 0.7);
    background: rgba(255, 255, 255, 0.25);
    transition: background 0.2s ease;
  }

  #fp-snap-{{ section_id }} .fp-snap__indicator span.is-active {
    background: #fff;
  }

  @media screen and (max-width: 768px) {
    #fp-snap-{{ section_id }} .fp-snap__wrapper {
      scroll-snap-type: y mandatory;
    }

    #fp-snap-{{ section_id }} .fp-snap__media--desktop {
      display: none;
    }

    #fp-snap-{{ section_id }} .fp-snap__media--mobile {
      display: block;
    }

    #fp-snap-{{ section_id }} .fp-snap__indicator {
      right: 1rem;
    }
  }
</style>

{%- if section.blocks.size > 1 -%}
  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const root = document.getElementById('fp-snap-{{ section_id }}');
      if (!root) return;

      const wrapper = root.querySelector('.fp-snap__wrapper');
      const dots = root.querySelectorAll('.fp-snap__indicator span');
      const panels = root.querySelectorAll('.fp-snap__panel');

      if (!wrapper || !panels.length) return;

      const updateIndicator = () => {
        const panelHeight = wrapper.clientHeight;
        if (!panelHeight) return;
        const scrollTop = wrapper.scrollTop;
        const activeIndex = Math.min(
          Math.round(scrollTop / panelHeight),
          panels.length - 1
        );

        dots.forEach((dot, index) => {
          dot.classList.toggle('is-active', index === activeIndex);
        });
      };

      wrapper.addEventListener('scroll', updateIndicator, { passive: true });
      window.addEventListener('resize', updateIndicator);
      wrapper.addEventListener('scrollend', updateIndicator);
      updateIndicator();
    });
  </script>
{%- endif -%}

