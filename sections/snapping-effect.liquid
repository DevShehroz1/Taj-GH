        'html.taj-snap-page .t4s-section-header .t4s-header__wrapper,html.taj-snap-page .t4s-header__wrapper,html.taj-snap-page body .t4s-header__wrapper{--h-text-color:#fff!important;--h-text-color-hover:rgba(255,255,255,0.8)!important;--h-text-color-rgb:255,255,255!important}' +
        'html.taj-snap-page .t4s-section-header a,html.taj-snap-page .t4s-section-header .t4s-push-menu-btn,html.taj-snap-page .t4s-section-header .t4s-site-nav__icon,html.taj-snap-page .t4s-section-header .t4s-site-nav__icons a,html.taj-snap-page .t4s-section-header .t4s-site-nav__cart a,html.taj-snap-page .t4s-section-header .t4s-col-group_btns a,html.taj-snap-page .t4s-section-header .t4s-col-group_btns .t4s-push-menu-btn{color:#fff!important}' +
        'html.taj-snap-page .t4s-section-header svg,html.taj-snap-page .t4s-section-header .t4s-push-menu-btn svg,html.taj-snap-page .t4s-section-header .t4s-site-nav__icon svg,html.taj-snap-page .t4s-section-header .t4s-col-group_btns svg{color:#fff!important;fill:#fff!important;stroke:#fff!important}' +
      '}';
      var s = document.createElement('style');
      s.id = 'taj-mobile-header-white';
      s.textContent = css;
      (document.head || document.documentElement).appendChild(s);
    }
  }

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  var MOBILE_BP = 767;
  var WHEEL_THRESHOLD = 50;

  var htmlEl = document.documentElement;
  var dotsNav = document.querySelector('.taj-snap-dots');
  var targets = [];
  var currentIndex = 0;
  var isAnimating = false;
  var cooldownId = null;
  var wheelDelta = 0;
  var wheelTimer = null;
  var scrollRAF = null;
  var scrollSettleTimer = null;
  var isScrolling = false;

  function isMobile() {
    return window.innerWidth <= MOBILE_BP;
  }

  function isInsideHeader(el) {
    while (el && el !== document) {
      if (el.classList && (
        el.classList.contains('t4s-section-header') ||
        el.classList.contains('t4s-mega-menu') ||
        el.hasAttribute('data-allow-scroll')
      )) return true;
      el = el.parentNode;
    }
    return false;
  }

  function buildTargets() {
    targets = [];
    var panels = document.querySelectorAll('[data-snap-panel]');
    for (var i = 0; i < panels.length; i++) {
      var panel = panels[i];
      if (isMobile() && panel.hasAttribute('data-snap-collections')) {
        var cards = panel.querySelectorAll('[data-snap-col]');
        for (var j = 0; j < cards.length; j++) {
          targets.push(cards[j]);
        }
      } else {
        targets.push(panel);
      }
    }

    /* Extra sections and footer: no snapping — scroll freely after banner panels */
  }

  function buildDots() {
    if (!dotsNav) return;
    dotsNav.innerHTML = '';
    for (var i = 0; i < targets.length; i++) {
      var btn = document.createElement('button');
      btn.className = 'taj-snap-dots__dot';
      btn.setAttribute('aria-label', 'Go to section ' + (i + 1));
      btn.setAttribute('data-dot-index', i);
      if (i === 0) btn.classList.add('is-active');
      dotsNav.appendChild(btn);
    }
  }

  function setActiveDot(index) {
    if (!dotsNav) return;
    var dots = dotsNav.querySelectorAll('.taj-snap-dots__dot');
    for (var i = 0; i < dots.length; i++) {
      if (i === index) {
        dots[i].classList.add('is-active');
      } else {
        dots[i].classList.remove('is-active');
      }
    }
  }

  function detectIndex() {
    var vh = window.innerHeight;
    var viewportMid = vh * 0.5;
    var best = 0;
    var bestDist = Infinity;
    for (var i = 0; i < targets.length; i++) {
      var rect = targets[i].getBoundingClientRect();
      var targetMid = rect.top + rect.height * 0.5;
      var dist = Math.abs(targetMid - viewportMid);
      if (dist < bestDist) {
        bestDist = dist;
        best = i;
      }
    }
    return best;
  }

  function setInView(forceCleanup) {
    for (var i = 0; i < targets.length; i++) {
      var rect = targets[i].getBoundingClientRect();
      var visible = rect.top < window.innerHeight * 0.6 && rect.bottom > window.innerHeight * 0.4;
      if (visible) {
        targets[i].classList.add('is-in-view');
      } else if (!isMobile() || forceCleanup) {
        targets[i].classList.remove('is-in-view');
