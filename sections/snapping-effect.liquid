  function forceMobileHeaderWhite() {
    if (!htmlEl.classList.contains('taj-snap-page') || !isMobile()) return;

    if (!document.getElementById('taj-mobile-header-white')) {
      var css = '@media (max-width:767px){html.taj-snap-page .t4s-header__wrapper{--h-text-color:#fff!important;--h-text-color-rgb:255,255,255!important}html.taj-snap-page .t4s-section-header a,html.taj-snap-page .t4s-section-header .t4s-push-menu-btn,html.taj-snap-page .t4s-section-header .t4s-site-nav__icon,html.taj-snap-page .t4s-section-header .t4s-site-nav__icons a,html.taj-snap-page .t4s-section-header .t4s-site-nav__cart a{color:#fff!important}html.taj-snap-page .t4s-section-header svg{color:#fff!important;fill:#fff!important;stroke:#fff!important}}';
      var s = document.createElement('style');
      s.id = 'taj-mobile-header-white';
      s.textContent = css;
      (document.head || document.documentElement).appendChild(s);
    }

    var wrapper = document.querySelector('.t4s-header__wrapper');
    if (wrapper) {
      wrapper.style.setProperty('--h-text-color', '#fff', 'important');
      wrapper.style.setProperty('--h-text-color-hover', 'rgba(255,255,255,0.8)', 'important');
      wrapper.style.setProperty('--h-text-color-rgb', '255, 255, 255', 'important');
    }
    var header = document.querySelector('.t4s-section-header');
    if (header) {
      [].forEach.call(header.querySelectorAll('a, .t4s-push-menu-btn, .t4s-site-nav__icon'), function(el) {
        el.style.setProperty('color', '#fff', 'important');
      });
      [].forEach.call(header.querySelectorAll('svg'), function(el) {
        el.style.setProperty('color', '#fff', 'important');
        el.style.setProperty('fill', '#fff', 'important');
        el.style.setProperty('stroke', '#fff', 'important');
      });
    }
  }

  function unlock() {
    isAnimating = false;
  }

  function scrollToIndex(index) {
    if (index < 0 || index >= targets.length || isAnimating) return;
    isAnimating = true;
    currentIndex = index;
    setActiveDot(index);
    updateHeaderColor(index);

    var rect = targets[index].getBoundingClientRect();
    var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    var absTop = Math.max(0, Math.round(rect.top + scrollTop));

    clearTimeout(cooldownId);

    if (isMobile()) {
      window.scrollTo({ top: absTop, behavior: 'auto' });
      cooldownId = setTimeout(function() {
        setInView(true);
        unlock();
      }, 120);
    } else {
      htmlEl.style.scrollSnapType = 'none';
      window.scrollTo({ top: absTop, behavior: 'smooth' });

      var finish = function() {
        htmlEl.style.scrollSnapType = '';
        setTimeout(unlock, 80);
      };

      if ('onscrollend' in window) {
        var done = function() {
          window.removeEventListener('scrollend', done);
          clearTimeout(cooldownId);
          finish();
        };
        window.addEventListener('scrollend', done);
        cooldownId = setTimeout(finish, 500);
      } else {
        cooldownId = setTimeout(finish, 400);
      }
    }
  }

  function onWheel(e) {
    if (isInsideHeader(e.target)) return;

    e.preventDefault();
    if (isAnimating) return;

    wheelDelta += e.deltaY;
    clearTimeout(wheelTimer);

    if (Math.abs(wheelDelta) >= WHEEL_THRESHOLD) {
      var dir = wheelDelta > 0 ? 1 : -1;
      wheelDelta = 0;
      currentIndex = detectIndex();
      scrollToIndex(currentIndex + dir);
    } else {
      wheelTimer = setTimeout(function() { wheelDelta = 0; }, 200);
    }
  }

  function onScroll() {
    if (scrollRAF) return;
    scrollRAF = requestAnimationFrame(function() {
      scrollRAF = null;
      if (!isAnimating) {
        currentIndex = detectIndex();
        setActiveDot(currentIndex);
        updateHeaderColor(currentIndex);
      }
      setInView(false);

      if (isMobile()) {
        isScrolling = true;
        clearTimeout(scrollSettleTimer);
        scrollSettleTimer = setTimeout(function() {
          isScrolling = false;
          setInView(true);
        }, 80);
      }
    });
  }

  function onTouchMove(e) {
    if (isMobile()) return;
    if (isInsideHeader(e.target)) return;
    if (isAnimating) e.preventDefault();
  }

  function onKeydown(e) {
    if (isAnimating) return;
    var tag = e.target.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || e.target.isContentEditable) return;

    currentIndex = detectIndex();

    switch (e.key) {
      case 'ArrowDown':
      case 'PageDown':
        e.preventDefault();
        scrollToIndex(currentIndex + 1);
        break;
      case 'ArrowUp':
      case 'PageUp':
        e.preventDefault();
        scrollToIndex(currentIndex - 1);
        break;
      case 'Home':
        e.preventDefault();
        scrollToIndex(0);
        break;
      case 'End':
        e.preventDefault();
        scrollToIndex(targets.length - 1);
        break;
    }
  }

  function onDotClick(e) {
    var btn = e.target.closest('.taj-snap-dots__dot');
    if (!btn) return;
    var idx = parseInt(btn.getAttribute('data-dot-index'), 10);
    if (!isNaN(idx)) {
      currentIndex = idx;
      scrollToIndex(idx);
    }
  }

  var resizeTimer;
  function onResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      buildTargets();
      buildDots();
      currentIndex = detectIndex();
      setActiveDot(currentIndex);
      updateHeaderColor(currentIndex);
      setInView();
      if (isMobile()) forceMobileHeaderWhite();
    }, 250);
  }

  function init() {
    buildTargets();
    buildDots();
    setInView();
    updateHeaderColor(0);
    if (isMobile()) forceMobileHeaderWhite();

    if (targets.length > 0) {
      targets[0].classList.add('is-in-view');
    }

    if (isMobile()) {
      window.addEventListener('load', forceMobileHeaderWhite);
      var mo = new MutationObserver(function() {
        if (isMobile()) forceMobileHeaderWhite();
      });
      mo.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      mo.observe(document.body, { attributes: true, attributeFilter: ['class'] });
    }

    window.addEventListener('wheel', onWheel, { passive: false });
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('keydown', onKeydown);
    window.addEventListener('resize', onResize);
    window.addEventListener('touchmove', onTouchMove, { passive: false });

    if (dotsNav) dotsNav.addEventListener('click', onDotClick);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

