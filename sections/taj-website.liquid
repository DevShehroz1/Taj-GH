<script>
  document.documentElement.classList.add('taj-snap-page');
  (function() {
    var setVh = function() {
      var h = (window.visualViewport && window.visualViewport.height) || window.innerHeight;
      document.documentElement.style.setProperty('--taj-vh', Math.round(h) + 'px');
    };
    setVh();
    window.addEventListener('resize', setVh);
    window.addEventListener('orientationchange', function() { setTimeout(setVh, 200); });
    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', setVh);
      window.visualViewport.addEventListener('scroll', setVh);
    }
    document.addEventListener('DOMContentLoaded', function() {
      setVh();
      setTimeout(setVh, 100);
      setTimeout(setVh, 350);
    });
  })();
</script>

<style>
  /* ═══════════════════════════════════════════
     FULL-PAGE SNAP SCROLL — applied to html
     Only active when taj-snap-page class is set
     (set immediately via inline script above)
     ═══════════════════════════════════════════ */

  html.taj-snap-page {
    scroll-snap-type: y mandatory;
    scroll-padding: 0;
    scrollbar-width: none;
    overflow-y: scroll;
    overflow-x: hidden;
  }
  html.taj-snap-page::-webkit-scrollbar { display: none; }

  html.taj-snap-page body {
    overflow-x: hidden;
    scrollbar-width: none;
  }
  html.taj-snap-page body::-webkit-scrollbar { display: none; }

  /* ═══ FIXED HEADER OVERLAY ═══
     Force header to fixed position so it floats
     above all snap panels on the homepage */

  html.taj-snap-page .t4s-section-header {
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    right: 0 !important;
    width: 100% !important;
    z-index: 500 !important;
    margin: 0 !important;
    box-sizing: border-box;
    box-shadow: none !important;
    border: none !important;
    transition: --h-text-color 0.3s ease, --h-bg-color 0.3s ease;
  }

  html.taj-snap-page .t4s-header__wrapper {
    background-color: transparent !important;
  }

  @media (min-width: 768px) {
    html.taj-snap-page.taj-header-light .t4s-header__wrapper {
      --h-text-color: #fff !important;
      --h-text-color-hover: rgba(255,255,255,0.7) !important;
      --h-bg-color: transparent !important;
    }
    html.taj-snap-page.taj-header-dark .t4s-header__wrapper {
      --h-text-color: #000 !important;
      --h-text-color-hover: rgba(0,0,0,0.6) !important;
      --h-bg-color: transparent !important;
    }
  }

  /* ═══ MOBILE: white header icons + white menu drawer (snap page only)
      Override .is-header--stuck so theme sticky header colors don’t switch to black ═══ */
  @media (max-width: 767px) {
    html.taj-snap-page .t4s-header__wrapper,
    html.taj-snap-page .is-header--stuck .t4s-header__wrapper {
      --h-text-color: #fff !important;
      --h-text-color-hover: rgba(255,255,255,0.8) !important;
      --h-text-color-rgb: 255, 255, 255 !important;
    }
    html.taj-snap-page .t4s-section-header .t4s-push-menu-btn,
    html.taj-snap-page .t4s-section-header .t4s-site-nav__cart > a,
    html.taj-snap-page .t4s-section-header .t4s-site-nav__icon a,
    html.taj-snap-page .is-header--stuck .t4s-push-menu-btn,
    html.taj-snap-page .is-header--stuck .t4s-site-nav__cart > a,
    html.taj-snap-page .is-header--stuck .t4s-site-nav__icon a {
      color: #fff !important;
    }
    html.taj-snap-page .t4s-section-header .t4s-push-menu-btn svg,
    html.taj-snap-page .t4s-section-header .t4s-site-nav__icon svg,
    html.taj-snap-page .t4s-section-header .t4s-site-nav__icon a svg,
    html.taj-snap-page .is-header--stuck .t4s-push-menu-btn svg,
    html.taj-snap-page .is-header--stuck .t4s-site-nav__icon svg,
    html.taj-snap-page .is-header--stuck .t4s-site-nav__icon a svg {
      color: #fff !important;
      fill: #fff !important;
    }
    html.taj-snap-page .t4s-push-menu-btn:hover,
    html.taj-snap-page .t4s-site-nav__cart > a:hover,
    html.taj-snap-page .t4s-site-nav__icon a:hover,
    html.taj-snap-page .is-header--stuck .t4s-push-menu-btn:hover,
    html.taj-snap-page .is-header--stuck .t4s-site-nav__cart > a:hover,
    html.taj-snap-page .is-header--stuck .t4s-site-nav__icon a:hover {
      color: rgba(255,255,255,0.8) !important;
    }
    /* Menu drawer keeps theme default (dark text) - white background needs readable text */
  }

  html.taj-snap-page #shopify-section-announcement-bar,
  html.taj-snap-page #shopify-section-top-bar {
    display: none !important;
  }

  /* ═══ SECTION SPACING — no gaps, no peeking ═══ */
  html.taj-snap-page #MainContent > div:has(.taj-snap),
  html.taj-snap-page .taj-snap {
    margin: 0 !important;
    padding: 0 !important;
    gap: 0 !important;
  }
  .taj-snap__panel {
    flex-shrink: 0;
    margin: 0 !important;
  }

  /* ═══ SNAP PANELS ═══
     scroll-snap-align: center prevents next section peeking into view */

  .taj-snap__panel {
    scroll-snap-align: center;
    scroll-snap-stop: always;
    min-height: 100vh;
    min-height: 100dvh;
    height: 100vh;
    height: 100dvh;
    box-sizing: border-box;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  /* ═══ MEDIA — Video & Image banners ═══ */

  .taj-snap__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .taj-snap__media video,
  .taj-snap__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ═══ TEXT OVERLAY ═══ */

  .taj-snap__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 60px;
    text-align: center;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.35) 100%);
  }
  .taj-snap__title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 8px;
  }
  .taj-snap__cta {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .taj-snap__cta:hover { opacity: 1; }

  /* ═══ TWO-COLLECTION GRID PANEL ═══ */

  .taj-snap__panel--collections {
    background: #fff;
  }
  .taj-snap__collections {
    display: flex;
    height: 100%;
    width: 100%;
    gap: 24px;
    padding: 80px 100px 0;
    box-sizing: border-box;
  }
  .taj-snap__col-card {
    flex: 1;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .taj-snap__col-image {
    flex: 1;
    overflow: hidden;
  }
  .taj-snap__col-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    display: block;
  }
  .taj-snap__col-info {
    padding: 18px 16px 24px;
    text-align: center;
    background: #fff;
    flex-shrink: 0;
  }
  .taj-snap__col-title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 6px;
  }
  .taj-snap__col-cta {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #000;
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .taj-snap__col-cta:hover { opacity: 1; }

  /* ═══ DESKTOP / MOBILE IMAGE SWITCH ═══ */

  .taj-snap__media--desktop { display: block; }
  .taj-snap__media--mobile  { display: none;  }

  /* ═══ EXTRA SECTIONS AS SNAP TARGETS ═══ */

  .taj-extra-snap {
    scroll-snap-align: center;
    scroll-snap-stop: always;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex !important;
    flex-direction: column;
    justify-content: center;
    align-items: stretch;
    box-sizing: border-box;
    padding: 60px 0;
  }

  .taj-extra-snap > * {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease 0.1s, transform 0.8s ease 0.1s;
  }
  .taj-extra-snap.is-in-view > * {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══ FOOTER AS LAST SNAP TARGET ═══ */

  html.taj-snap-page #t4s-footer {
    scroll-snap-align: center;
    scroll-snap-stop: always;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
  }

  /* ═══ DOT INDICATORS ═══ */

  .taj-snap-dots {
    position: fixed;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 600;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .taj-snap-dots__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.7);
    background: transparent;
    cursor: pointer;
    transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s ease;
    padding: 0;
    -webkit-appearance: none;
    appearance: none;
  }
  .taj-snap-dots__dot:hover {
    background: rgba(255,255,255,0.5);
  }
  .taj-snap-dots__dot.is-active {
    background: #fff;
    border-color: #fff;
    transform: scale(1.35);
  }

  /* ═══ PANEL ENTRANCE ANIMATIONS ═══ */

  .taj-snap__overlay > * {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.7s ease 0.15s, transform 0.7s ease 0.15s;
  }
  .taj-snap__panel.is-in-view .taj-snap__overlay > * {
    opacity: 1;
    transform: translateY(0);
  }
  .taj-snap__panel.is-in-view .taj-snap__overlay > *:nth-child(2) {
    transition-delay: 0.35s;
  }
  .taj-snap__col-info {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.6s ease 0.2s, transform 0.6s ease 0.2s;
  }
  .taj-snap__panel.is-in-view .taj-snap__col-info,
  .taj-snap__col-card.is-in-view .taj-snap__col-info {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══ MOBILE — max-width: 767px
      One full banner only. --taj-vh from visualViewport for iOS Safari/Chrome. ═══ */

  @media (max-width: 767px) {
    html.taj-snap-page {
      overscroll-behavior-y: none;
      -webkit-overflow-scrolling: touch;
    }
    .taj-snap__panel {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      height: var(--taj-vh, 100vh);
      min-height: var(--taj-vh, 100vh);
      overflow: hidden;
      box-sizing: border-box;
    }
    .taj-snap__media--desktop { display: none;  }
    .taj-snap__media--mobile  { display: block; }

    .taj-snap__panel--collections {
      height: auto;
      scroll-snap-align: none;
      scroll-snap-stop: normal;
      overflow: visible;
    }
    .taj-snap__collections {
      flex-direction: column;
      gap: 0;
      height: auto;
      padding: 0;
    }
    .taj-snap__col-card {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      height: var(--taj-vh, 100vh);
      min-height: var(--taj-vh, 100vh);
      flex: none;
      overflow: hidden;
      box-sizing: border-box;
    }
    .taj-snap__col-image img {
      object-fit: cover;
      object-position: center center;
    }

    .taj-snap__col-info { padding: 14px 10px 20px; }
    .taj-snap__col-title { font-size: 11px; letter-spacing: 1.5px; }
    .taj-snap__col-cta  { font-size: 10px; }
    .taj-snap__title    { font-size: 12px; }
    .taj-snap__cta      { font-size: 11px; }
    .taj-snap__overlay  { padding-bottom: 46px; }

    .taj-extra-snap,
    html.taj-snap-page #t4s-footer {
      scroll-snap-align: start;
      height: var(--taj-vh, 100vh);
      min-height: var(--taj-vh, 100vh);
      overflow: hidden;
      box-sizing: border-box;
    }
    .taj-snap-dots {
      right: 14px;
      gap: 8px;
    }
    .taj-snap-dots__dot {
      width: 6px;
      height: 6px;
    }
  }

  /* ═══ REDUCED MOTION ═══ */

  @media (prefers-reduced-motion: reduce) {
    html.taj-snap-page { scroll-snap-type: none !important; scroll-behavior: auto !important; }
    .taj-snap__panel, .taj-snap__col-card, .taj-extra-snap, html.taj-snap-page #t4s-footer {
      scroll-snap-align: none !important;
      scroll-snap-stop: normal !important;
    }
    .taj-snap__overlay > *,
    .taj-snap__col-info,
    .taj-extra-snap > * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .taj-snap-dots { display: none; }
  }
</style>

{%- comment -%} Dot navigation — populated by JS {%- endcomment -%}
<nav class="taj-snap-dots" aria-label="Section navigation"></nav>

<div class="taj-snap" data-section-id="{{ section.id }}">

  {%- comment -%} Panel 1: Video Banner (or static fallback) {%- endcomment -%}
  {% assign has_video_desktop = false %}
  {% if section.settings.video_1 != blank or section.settings.video_1_url != blank %}
    {% assign has_video_desktop = true %}
  {% endif %}
  {% assign has_video_mobile = false %}
  {% if section.settings.video_1_mobile != blank or section.settings.video_1_url_mobile != blank %}
    {% assign has_video_mobile = true %}
  {% endif %}
  {% assign has_banner_desktop = section.settings.video_1_image_desktop != blank %}
  {% assign has_banner_mobile = section.settings.video_1_image_mobile != blank %}
  {% if has_video_desktop or has_video_mobile or has_banner_desktop or has_banner_mobile %}
    <div class="taj-snap__panel" data-snap-panel>
      {%- comment -%} Desktop: video or static image {%- endcomment -%}
      <div class="taj-snap__media taj-snap__media--desktop">
        {% if has_video_desktop %}
          {% if section.settings.video_1 != blank %}
            {{ section.settings.video_1 | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, controls: false }}
          {% else %}
            <video autoplay muted loop playsinline>
              <source src="{{ section.settings.video_1_url }}" type="video/mp4">
            </video>
          {% endif %}
        {% elsif has_banner_desktop %}
          <img src="{{ section.settings.video_1_image_desktop | image_url: width: 1920 }}" alt="{{ section.settings.video_1_title | escape }}" loading="lazy">
        {% endif %}
      </div>
      {%- comment -%} Mobile: video or static image {%- endcomment -%}
      <div class="taj-snap__media taj-snap__media--mobile">
        {% if has_video_mobile %}
          {% if section.settings.video_1_mobile != blank %}
            {{ section.settings.video_1_mobile | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, controls: false }}
          {% else %}
            <video autoplay muted loop playsinline>
              <source src="{{ section.settings.video_1_url_mobile }}" type="video/mp4">
            </video>
          {% endif %}
        {% elsif has_video_desktop %}
          {% if section.settings.video_1 != blank %}
            {{ section.settings.video_1 | video_tag: autoplay: true, muted: true, loop: true, playsinline: true, controls: false }}
          {% else %}
            <video autoplay muted loop playsinline>
              <source src="{{ section.settings.video_1_url }}" type="video/mp4">
            </video>
          {% endif %}
        {% elsif has_banner_mobile %}
          <img src="{{ section.settings.video_1_image_mobile | image_url: width: 800 }}" alt="{{ section.settings.video_1_title | escape }}" loading="lazy">
        {% elsif has_banner_desktop %}
          <img src="{{ section.settings.video_1_image_desktop | image_url: width: 800 }}" alt="{{ section.settings.video_1_title | escape }}" loading="lazy">
        {% endif %}
      </div>
      <div class="taj-snap__overlay">
        {% if section.settings.video_1_title != blank %}
          <p class="taj-snap__title">{{ section.settings.video_1_title }}</p>
        {% endif %}
        {% if section.settings.video_1_cta_text != blank %}
          <a href="{{ section.settings.video_1_cta_link }}" class="taj-snap__cta">{{ section.settings.video_1_cta_text }}</a>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {%- comment -%} Panel 2: Two Collections {%- endcomment -%}
  {% assign show_col2 = section.settings.collection_2 != blank or (section.settings.collection_2_link != blank and section.settings.collection_2_image != blank) %}
  {% if section.settings.collection_1 != blank or show_col2 %}
    <div class="taj-snap__panel taj-snap__panel--collections" data-snap-panel data-snap-collections>
      <div class="taj-snap__collections">

        {% if section.settings.collection_1 != blank %}
          {% assign col1 = section.settings.collection_1 %}
          <div class="taj-snap__col-card" data-snap-col>
            <a href="{{ col1.url }}" class="taj-snap__col-image">
              {% if section.settings.collection_1_image != blank %}
                <img src="{{ section.settings.collection_1_image | image_url: width: 800 }}" alt="{{ col1.title | escape }}" loading="lazy">
              {% elsif col1.image %}
                <img src="{{ col1.image | image_url: width: 800 }}" alt="{{ col1.title | escape }}" loading="lazy">
              {% endif %}
            </a>
            <div class="taj-snap__col-info">
              <p class="taj-snap__col-title">{{ section.settings.collection_1_heading | default: col1.title }}</p>
              <a href="{{ col1.url }}" class="taj-snap__col-cta">{{ section.settings.collection_1_cta | default: 'Explore' }}</a>
            </div>
          </div>
        {% endif %}

        {% if show_col2 %}
          {% assign col2 = section.settings.collection_2 %}
          {% assign col2_url = section.settings.collection_2_link %}
          {% if col2 != blank and section.settings.collection_2_link == blank %}
            {% assign col2_url = col2.url %}
          {% endif %}
          {% if col2_url != blank %}
          <div class="taj-snap__col-card" data-snap-col>
            <a href="{{ col2_url }}" class="taj-snap__col-image">
              {% if section.settings.collection_2_image != blank %}
                <img src="{{ section.settings.collection_2_image | image_url: width: 800 }}" alt="{{ section.settings.collection_2_heading | default: 'Collection 2' | escape }}" loading="lazy">
              {% elsif col2 != blank and col2.image %}
                <img src="{{ col2.image | image_url: width: 800 }}" alt="{{ section.settings.collection_2_heading | default: col2.title | escape }}" loading="lazy">
              {% endif %}
            </a>
            <div class="taj-snap__col-info">
              <p class="taj-snap__col-title">{% if section.settings.collection_2_heading != blank %}{{ section.settings.collection_2_heading }}{% elsif col2 != blank %}{{ col2.title }}{% else %}Collection{% endif %}</p>
              <a href="{{ col2_url }}" class="taj-snap__col-cta">{{ section.settings.collection_2_cta | default: 'Discover' }}</a>
            </div>
          </div>
          {% endif %}
        {% endif %}

      </div>
    </div>
  {% endif %}

  {%- comment -%} Panel 3: Image Banner 1 {%- endcomment -%}
  {% if section.settings.banner_1_image != blank %}
    <div class="taj-snap__panel" data-snap-panel>
      <div class="taj-snap__media taj-snap__media--desktop">
        <img src="{{ section.settings.banner_1_image | image_url: width: 1920 }}" alt="{{ section.settings.banner_1_title | escape }}" loading="lazy">
      </div>
      <div class="taj-snap__media taj-snap__media--mobile">
        {% if section.settings.banner_1_image_mobile != blank %}
          <img src="{{ section.settings.banner_1_image_mobile | image_url: width: 800 }}" alt="{{ section.settings.banner_1_title | escape }}" loading="lazy">
        {% else %}
          <img src="{{ section.settings.banner_1_image | image_url: width: 800 }}" alt="{{ section.settings.banner_1_title | escape }}" loading="lazy">
        {% endif %}
      </div>
      <div class="taj-snap__overlay">
        {% if section.settings.banner_1_title != blank %}
          <p class="taj-snap__title">{{ section.settings.banner_1_title }}</p>
        {% endif %}
        {% if section.settings.banner_1_cta_text != blank %}
          <a href="{{ section.settings.banner_1_cta_link }}" class="taj-snap__cta">{{ section.settings.banner_1_cta_text }}</a>
        {% endif %}
      </div>
    </div>
  {% endif %}

  {%- comment -%} Panel 4: Image Banner 2 {%- endcomment -%}
  {% if section.settings.banner_2_image != blank %}
    <div class="taj-snap__panel" data-snap-panel>
      <div class="taj-snap__media taj-snap__media--desktop">
        <img src="{{ section.settings.banner_2_image | image_url: width: 1920 }}" alt="{{ section.settings.banner_2_title | escape }}" loading="lazy">
      </div>
      <div class="taj-snap__media taj-snap__media--mobile">
        {% if section.settings.banner_2_image_mobile != blank %}
          <img src="{{ section.settings.banner_2_image_mobile | image_url: width: 800 }}" alt="{{ section.settings.banner_2_title | escape }}" loading="lazy">
        {% else %}
          <img src="{{ section.settings.banner_2_image | image_url: width: 800 }}" alt="{{ section.settings.banner_2_title | escape }}" loading="lazy">
        {% endif %}
      </div>
      <div class="taj-snap__overlay">
        {% if section.settings.banner_2_title != blank %}
          <p class="taj-snap__title">{{ section.settings.banner_2_title }}</p>
        {% endif %}
        {% if section.settings.banner_2_cta_text != blank %}
          <a href="{{ section.settings.banner_2_cta_link }}" class="taj-snap__cta">{{ section.settings.banner_2_cta_text }}</a>
        {% endif %}
      </div>
    </div>
  {% endif %}

</div>

<script>
(function() {
  'use strict';

  /* Inject mobile header white CSS immediately - must run before theme scripts */
  if (document.documentElement.classList.contains('taj-snap-page') && window.innerWidth <= 767) {
    if (!document.getElementById('taj-mobile-header-white')) {
      var css = '@media (max-width:767px){' +
        'html.taj-snap-page .t4s-section-header .t4s-header__wrapper,html.taj-snap-page .t4s-header__wrapper,html.taj-snap-page body .t4s-header__wrapper{--h-text-color:#fff!important;--h-text-color-hover:rgba(255,255,255,0.8)!important;--h-text-color-rgb:255,255,255!important}' +
        'html.taj-snap-page .t4s-section-header a,html.taj-snap-page .t4s-section-header .t4s-push-menu-btn,html.taj-snap-page .t4s-section-header .t4s-site-nav__icon,html.taj-snap-page .t4s-section-header .t4s-site-nav__icons a,html.taj-snap-page .t4s-section-header .t4s-site-nav__cart a,html.taj-snap-page .t4s-section-header .t4s-col-group_btns a,html.taj-snap-page .t4s-section-header .t4s-col-group_btns .t4s-push-menu-btn{color:#fff!important}' +
        'html.taj-snap-page .t4s-section-header svg,html.taj-snap-page .t4s-section-header .t4s-push-menu-btn svg,html.taj-snap-page .t4s-section-header .t4s-site-nav__icon svg,html.taj-snap-page .t4s-section-header .t4s-col-group_btns svg{color:#fff!important;fill:#fff!important;stroke:#fff!important}' +
      '}';
      var s = document.createElement('style');
      s.id = 'taj-mobile-header-white';
      s.textContent = css;
      (document.head || document.documentElement).appendChild(s);
    }
  }

  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

  var MOBILE_BP = 767;
  var WHEEL_THRESHOLD = 50;

  var htmlEl = document.documentElement;
  var dotsNav = document.querySelector('.taj-snap-dots');
  var targets = [];
  var currentIndex = 0;
  var isAnimating = false;
  var cooldownId = null;
  var wheelDelta = 0;
  var wheelTimer = null;
  var scrollRAF = null;

  function isMobile() {
    return window.innerWidth <= MOBILE_BP;
  }

  function isInsideHeader(el) {
    while (el && el !== document) {
      if (el.classList && (
        el.classList.contains('t4s-section-header') ||
        el.classList.contains('t4s-mega-menu') ||
        el.hasAttribute('data-allow-scroll')
      )) return true;
      el = el.parentNode;
    }
    return false;
  }

  function buildTargets() {
    targets = [];
    var panels = document.querySelectorAll('[data-snap-panel]');
    for (var i = 0; i < panels.length; i++) {
      var panel = panels[i];
      if (isMobile() && panel.hasAttribute('data-snap-collections')) {
        var cards = panel.querySelectorAll('[data-snap-col]');
        for (var j = 0; j < cards.length; j++) {
          targets.push(cards[j]);
        }
      } else {
        targets.push(panel);
      }
    }

    var mainEl = document.getElementById('MainContent');
    var footer = document.getElementById('t4s-footer');
    if (mainEl) {
      var children = mainEl.children;
      var foundSnap = false;
      for (var i = 0; i < children.length; i++) {
        var child = children[i];
        if (child.querySelector('.taj-snap') || child.querySelector('[data-snap-panel]')) {
          foundSnap = true;
          continue;
        }
        if (foundSnap && child.children.length > 0) {
          child.classList.add('taj-extra-snap');
          targets.push(child);
        }
      }
    }
    if (footer) targets.push(footer);
  }

  function buildDots() {
    if (!dotsNav) return;
    dotsNav.innerHTML = '';
    for (var i = 0; i < targets.length; i++) {
      var btn = document.createElement('button');
      btn.className = 'taj-snap-dots__dot';
      btn.setAttribute('aria-label', 'Go to section ' + (i + 1));
      btn.setAttribute('data-dot-index', i);
      if (i === 0) btn.classList.add('is-active');
      dotsNav.appendChild(btn);
    }
  }

  function setActiveDot(index) {
    if (!dotsNav) return;
    var dots = dotsNav.querySelectorAll('.taj-snap-dots__dot');
    for (var i = 0; i < dots.length; i++) {
      if (i === index) {
        dots[i].classList.add('is-active');
      } else {
        dots[i].classList.remove('is-active');
      }
    }
  }

  function detectIndex() {
    var vh = window.innerHeight;
    var viewportMid = vh * 0.5;
    var best = 0;
    var bestDist = Infinity;
    for (var i = 0; i < targets.length; i++) {
      var rect = targets[i].getBoundingClientRect();
      var targetMid = rect.top + rect.height * 0.5;
      var dist = Math.abs(targetMid - viewportMid);
      if (dist < bestDist) {
        bestDist = dist;
        best = i;
      }
    }
    return best;
  }

  function setInView() {
    for (var i = 0; i < targets.length; i++) {
      var rect = targets[i].getBoundingClientRect();
      var visible = rect.top < window.innerHeight * 0.6 && rect.bottom > window.innerHeight * 0.4;
      if (visible) {
        targets[i].classList.add('is-in-view');
      } else {
        targets[i].classList.remove('is-in-view');
      }
    }
  }

  var WHITE_LOGO = 'https://cdn.shopify.com/s/files/1/0720/2868/4423/files/54548548.png?v=1771260571';

  function updateHeaderColor(index) {
    var logo = document.querySelector('.header__normal-logo');
    if (logo && !logo.dataset.originalSrc) {
      logo.dataset.originalSrc = logo.src;
      logo.dataset.originalSrcset = logo.srcset || '';
    }

    if (index === 0) {
      htmlEl.classList.add('taj-header-light');
      htmlEl.classList.remove('taj-header-dark');
      if (logo) { logo.src = WHITE_LOGO; logo.srcset = ''; }
    } else {
      htmlEl.classList.remove('taj-header-light');
      htmlEl.classList.add('taj-header-dark');
      if (logo && logo.dataset.originalSrc) {
        logo.src = logo.dataset.originalSrc;
        logo.srcset = logo.dataset.originalSrcset;
      }
    }
    if (isMobile()) forceMobileHeaderWhite();
  }

  function forceMobileHeaderWhite() {
    if (!htmlEl.classList.contains('taj-snap-page') || !isMobile()) return;

    /* Inject CSS once if not already (backup) */
    if (!document.getElementById('taj-mobile-header-white')) {
      var css = '@media (max-width:767px){html.taj-snap-page .t4s-header__wrapper{--h-text-color:#fff!important;--h-text-color-rgb:255,255,255!important}html.taj-snap-page .t4s-section-header a,html.taj-snap-page .t4s-section-header .t4s-push-menu-btn,html.taj-snap-page .t4s-section-header .t4s-site-nav__icon,html.taj-snap-page .t4s-section-header .t4s-site-nav__icons a,html.taj-snap-page .t4s-section-header .t4s-site-nav__cart a{color:#fff!important}html.taj-snap-page .t4s-section-header svg{color:#fff!important;fill:#fff!important;stroke:#fff!important}}';
      var s = document.createElement('style');
      s.id = 'taj-mobile-header-white';
      s.textContent = css;
      (document.head || document.documentElement).appendChild(s);
    }

    /* Inline styles as backup */
    var wrapper = document.querySelector('.t4s-header__wrapper');
    if (wrapper) {
      wrapper.style.setProperty('--h-text-color', '#fff', 'important');
      wrapper.style.setProperty('--h-text-color-hover', 'rgba(255,255,255,0.8)', 'important');
      wrapper.style.setProperty('--h-text-color-rgb', '255, 255, 255', 'important');
    }
    var header = document.querySelector('.t4s-section-header');
    if (header) {
      [].forEach.call(header.querySelectorAll('a, .t4s-push-menu-btn, .t4s-site-nav__icon'), function(el) {
        el.style.setProperty('color', '#fff', 'important');
      });
      [].forEach.call(header.querySelectorAll('svg'), function(el) {
        el.style.setProperty('color', '#fff', 'important');
        el.style.setProperty('fill', '#fff', 'important');
        el.style.setProperty('stroke', '#fff', 'important');
      });
    }
  }

  function unlock() {
    isAnimating = false;
  }

  function scrollToIndex(index) {
    if (index < 0 || index >= targets.length || isAnimating) return;
    isAnimating = true;
    currentIndex = index;
    setActiveDot(index);
    updateHeaderColor(index);

    htmlEl.style.scrollSnapType = 'none';

    var rect = targets[index].getBoundingClientRect();
    var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    var absTop;
    if (isMobile()) {
      absTop = rect.top + scrollTop;
    } else {
      var vh = window.innerHeight;
      var targetHeight = rect.height;
      absTop = rect.top + scrollTop - (vh * 0.5) + (targetHeight * 0.5);
    }
    absTop = Math.max(0, Math.round(absTop));

    /* Mobile: instant scroll avoids conflict with native touch scroll-snap */
    var behavior = isMobile() ? 'auto' : 'smooth';
    window.scrollTo({ top: absTop, behavior: behavior });

    clearTimeout(cooldownId);

    function finish() {
      htmlEl.style.scrollSnapType = '';
      setTimeout(unlock, 80);
    }

    if (isMobile()) {
      finish();
    } else if ('onscrollend' in window) {
      var done = function() {
        window.removeEventListener('scrollend', done);
        clearTimeout(cooldownId);
        finish();
      };
      window.addEventListener('scrollend', done);
      cooldownId = setTimeout(finish, 1000);
    } else {
      cooldownId = setTimeout(finish, 700);
    }
  }

  function onWheel(e) {
    if (isInsideHeader(e.target)) return;

    e.preventDefault();
    if (isAnimating) return;

    wheelDelta += e.deltaY;
    clearTimeout(wheelTimer);

    if (Math.abs(wheelDelta) >= WHEEL_THRESHOLD) {
      var dir = wheelDelta > 0 ? 1 : -1;
      wheelDelta = 0;
      currentIndex = detectIndex();
      scrollToIndex(currentIndex + dir);
    } else {
      wheelTimer = setTimeout(function() { wheelDelta = 0; }, 200);
    }
  }

  function onScroll() {
    if (scrollRAF) return;
    scrollRAF = requestAnimationFrame(function() {
      scrollRAF = null;
      if (!isAnimating) {
        currentIndex = detectIndex();
        setActiveDot(currentIndex);
        updateHeaderColor(currentIndex);
      }
      setInView();
    });
  }

  function onTouchMove(e) {
    if (isInsideHeader(e.target)) return;
    if (isAnimating) e.preventDefault();
  }

  function onKeydown(e) {
    if (isAnimating) return;
    var tag = e.target.tagName;
    if (tag === 'INPUT' || tag === 'TEXTAREA' || tag === 'SELECT' || e.target.isContentEditable) return;

    currentIndex = detectIndex();

    switch (e.key) {
      case 'ArrowDown':
      case 'PageDown':
        e.preventDefault();
        scrollToIndex(currentIndex + 1);
        break;
      case 'ArrowUp':
      case 'PageUp':
        e.preventDefault();
        scrollToIndex(currentIndex - 1);
        break;
      case 'Home':
        e.preventDefault();
        scrollToIndex(0);
        break;
      case 'End':
        e.preventDefault();
        scrollToIndex(targets.length - 1);
        break;
    }
  }

  function onDotClick(e) {
    var btn = e.target.closest('.taj-snap-dots__dot');
    if (!btn) return;
    var idx = parseInt(btn.getAttribute('data-dot-index'), 10);
    if (!isNaN(idx)) {
      currentIndex = idx;
      scrollToIndex(idx);
    }
  }

  var resizeTimer;
  function onResize() {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(function() {
      buildTargets();
      buildDots();
      currentIndex = detectIndex();
      setActiveDot(currentIndex);
      updateHeaderColor(currentIndex);
      setInView();
      if (isMobile()) forceMobileHeaderWhite();
    }, 250);
  }

  function init() {
    buildTargets();
    buildDots();
    setInView();
    updateHeaderColor(0);
    if (isMobile()) forceMobileHeaderWhite();

    if (targets.length > 0) {
      targets[0].classList.add('is-in-view');
    }

    if (isMobile()) {
      window.addEventListener('load', forceMobileHeaderWhite);
      var mo = new MutationObserver(function() {
        if (isMobile()) forceMobileHeaderWhite();
      });
      mo.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });
      mo.observe(document.body, { attributes: true, attributeFilter: ['class'] });
    }

    window.addEventListener('wheel', onWheel, { passive: false });
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('keydown', onKeydown);
    window.addEventListener('resize', onResize);
    window.addEventListener('touchmove', onTouchMove, { passive: false });

    if (dotsNav) dotsNav.addEventListener('click', onDotClick);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script> 

