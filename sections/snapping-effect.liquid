    if (index === 0) {
      htmlEl.classList.add('taj-header-light');
      htmlEl.classList.remove('taj-header-dark');
      if (logo) { logo.src = WHITE_LOGO; logo.srcset = ''; }
    } else {
      htmlEl.classList.remove('taj-header-light');
      htmlEl.classList.add('taj-header-dark');
