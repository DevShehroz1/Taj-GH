  /* Collapse header wrapper so it doesn't add space to the document flow */
  html.taj-snap-page #shopify-section-header,
  html.taj-snap-page [id^="shopify-section-"][class*="header"] {
    height: 0 !important;
    min-height: 0 !important;
    overflow: visible !important;
  }

  /* ═══ SECTION SPACING — no gaps, no peeking ═══ */
  html.taj-snap-page #MainContent > div:has(.taj-snap),
  html.taj-snap-page .taj-snap {
    margin: 0 !important;
    padding: 0 !important;
    gap: 0 !important;
  }
  .taj-snap__panel {
    flex-shrink: 0;
    margin: 0 !important;
  }

  /* ═══ SNAP PANELS ═══ */

  .taj-snap__panel {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    min-height: 100vh;
    min-height: 100dvh;
    height: 100vh;
    height: 100dvh;
    box-sizing: border-box;
    width: 100%;
    position: relative;
    overflow: hidden;
  }

  /* ═══ MEDIA — Video & Image banners ═══ */

  .taj-snap__media {
    position: absolute;
    inset: 0;
    z-index: 0;
  }
  .taj-snap__media video,
  .taj-snap__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ═══ TEXT OVERLAY ═══ */

  .taj-snap__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    padding-bottom: 60px;
    text-align: center;
    background: linear-gradient(to bottom, transparent 60%, rgba(0,0,0,0.35) 100%);
  }
  .taj-snap__title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 8px;
  }
  .taj-snap__cta {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    opacity: 0.85;
    transition: opacity 0.2s;
  }
  .taj-snap__cta:hover { opacity: 1; }

  /* ═══ TWO-COLLECTION GRID PANEL ═══ */

  .taj-snap__panel--collections {
    background: #fff;
  }
  .taj-snap__collections {
    display: flex;
    height: 100%;
    width: 100%;
    gap: 24px;
    padding: 80px 100px 0;
    box-sizing: border-box;
  }
  .taj-snap__col-card {
    flex: 1;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  .taj-snap__col-image {
    flex: 1;
    overflow: hidden;
  }
  .taj-snap__col-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center bottom;
    display: block;
  }
  .taj-snap__col-info {
    padding: 18px 16px 24px;
    text-align: center;
    background: #fff;
    flex-shrink: 0;
  }
  .taj-snap__col-title {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #000;
    margin: 0 0 6px;
  }
  .taj-snap__col-cta {
    font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #000;
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s;
  }
  .taj-snap__col-cta:hover { opacity: 1; }

  /* ═══ DESKTOP / MOBILE IMAGE SWITCH ═══ */

  .taj-snap__media--desktop { display: block; }
  .taj-snap__media--mobile  { display: none;  }

  /* ═══ EXTRA SECTIONS — no snapping, scroll freely ═══ */

  .taj-extra-snap {
    scroll-snap-align: none;
    scroll-snap-stop: normal;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex !important;
    flex-direction: column;
    justify-content: center;
    align-items: stretch;
    box-sizing: border-box;
    padding: 60px 0;
  }

  .taj-extra-snap > * {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.35s ease 0.05s, transform 0.35s ease 0.05s;
    will-change: opacity, transform;
  }
  .taj-extra-snap.is-in-view > * {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══ FOOTER — no snapping, scroll freely ═══ */

  html.taj-snap-page #t4s-footer {
    scroll-snap-align: none;
    scroll-snap-stop: normal;
  }

  /* ═══ DOT INDICATORS ═══ */

  .taj-snap-dots {
    position: fixed;
    right: 24px;
    top: 50%;
    transform: translateY(-50%);
    z-index: 600;
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 0;
    margin: 0;
    list-style: none;
  }
  .taj-snap-dots__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,0.7);
    background: transparent;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
    padding: 0;
    -webkit-appearance: none;
    appearance: none;
  }
  .taj-snap-dots__dot:hover {
    background: rgba(255,255,255,0.5);
  }
  .taj-snap-dots__dot.is-active {
    background: #fff;
    border-color: #fff;
    transform: scale(1.35);
  }

  /* ═══ PANEL ENTRANCE ANIMATIONS ═══ */

  .taj-snap__overlay > * {
    opacity: 0;
    transform: translateY(18px);
    transition: opacity 0.4s ease 0.03s, transform 0.4s ease 0.03s;
    will-change: opacity, transform;
  }
  .taj-snap__panel.is-in-view .taj-snap__overlay > * {
    opacity: 1;
    transform: translateY(0);
  }
  .taj-snap__panel.is-in-view .taj-snap__overlay > *:nth-child(2) {
    transition-delay: 0.08s;
  }
  .taj-snap__col-info {
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.35s ease 0.03s, transform 0.35s ease 0.03s;
    will-change: opacity, transform;
  }
  .taj-snap__panel.is-in-view .taj-snap__col-info,
  .taj-snap__col-card.is-in-view .taj-snap__col-info {
    opacity: 1;
    transform: translateY(0);
  }

  /* ═══ MOBILE — max-width: 767px ═══ */

  @media (max-width: 767px) {
    html.taj-snap-page {
      /* proximity = panels snap crisply (full-viewport = always within threshold)
         but text columns + footer scroll freely since they have no snap-align */
      scroll-snap-type: y proximity;
      overscroll-behavior-y: none;
      -webkit-overflow-scrolling: touch;
      overflow-x: hidden;
    }
    html.taj-snap-page body {
      padding-top: 0 !important;
      margin-top: 0 !important;
      overflow-x: hidden;
    }
    html.taj-snap-page #MainContent {
      padding-top: 0 !important;
      margin-top: 0 !important;
    }
    .taj-snap__panel {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      height: var(--taj-vh, 100vh);
      min-height: var(--taj-vh, 100vh);
      overflow: hidden;
      box-sizing: border-box;
      position: relative;
    }
    @supports (height: 100lvh) {
      .taj-snap__panel {
        height: 100lvh;
        min-height: 100lvh;
      }
    }
    .taj-snap__media--desktop { display: none;  }
    .taj-snap__media--mobile  { display: block; }

    .taj-snap__panel--collections {
      height: auto;
      min-height: 0;
      max-height: none;
      scroll-snap-align: none;
      scroll-snap-stop: normal;
      overflow: visible;
    }
    .taj-snap__collections {
      flex-direction: column;
      gap: 0;
      height: auto;
      padding: 0;
    }
    .taj-snap__col-card {
      scroll-snap-align: start;
      scroll-snap-stop: always;
      height: var(--taj-vh, 100vh);
      min-height: var(--taj-vh, 100vh);
      flex: none;
      overflow: hidden;
      box-sizing: border-box;
      position: relative;
    }
    @supports (height: 100lvh) {
      .taj-snap__col-card {
        height: 100lvh;
        min-height: 100lvh;
      }
    }
    .taj-snap__col-image img {
      object-fit: cover;
      object-position: center center;
    }

    .taj-snap__col-info { padding: 14px 10px 20px; }
    .taj-snap__col-title { font-size: 11px; letter-spacing: 1.5px; }
    .taj-snap__col-cta  { font-size: 10px; }
    .taj-snap__title    { font-size: 12px; }
    .taj-snap__cta      { font-size: 11px; }
    .taj-snap__overlay  { padding-bottom: 46px; }

    /* No snapping for text columns and footer on mobile */
    html.taj-snap-page .t4s-feature-columns,
    html.taj-snap-page #t4s-footer {
      scroll-snap-align: none !important;
      scroll-snap-stop: normal !important;
      height: auto;
      min-height: 0;
      max-height: none;
      overflow: visible;
    }
    .taj-snap-dots {
      right: 14px;
      gap: 8px;
    }
    .taj-snap-dots__dot {
      width: 6px;
      height: 6px;
    }
  }

  /* ═══ REDUCED MOTION ═══ */

  @media (prefers-reduced-motion: reduce) {
    html.taj-snap-page { scroll-snap-type: none !important; scroll-behavior: auto !important; }
    .taj-snap__panel, .taj-snap__col-card, .taj-extra-snap, html.taj-snap-page #t4s-footer {
      scroll-snap-align: none !important;
      scroll-snap-stop: normal !important;
    }
    .taj-snap__overlay > *,
    .taj-snap__col-info,
    .taj-extra-snap > * {
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
    .taj-snap-dots { display: none; }
  }
</style>

